# ============================================================
# Quran Tafseer RAG — Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- PostgreSQL / pgvector ---
POSTGRES_USER=tafseer
POSTGRES_PASSWORD=tafseer_secret
POSTGRES_DB=quran_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Connection URL (auto-built from above, or override directly)
# DATABASE_URL=postgresql://tafseer:tafseer_secret@localhost:5432/quran_rag

# --- HuggingFace (Embedding) ---
# Get your free token at: https://huggingface.co/settings/tokens
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Groq (LLM Generation) ---
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Embedding config ---
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024

# --- LLM config ---
LLM_MODEL=llama-3.3-70b-versatile
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.1

# --- RAG config ---
TOP_K=5                    # Number of chunks to retrieve
HYBRID_ALPHA=0.7           # Weight for vector vs trigram (1.0 = pure vector)
